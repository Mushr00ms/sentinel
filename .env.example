# Sonic RPC (required)
RPC_URL_146=https://rpc.soniclabs.com
WS_URL_146=wss://rpc.soniclabs.com

# Wallet (required)
PRIVATE_KEY=0x...

# Contract addresses (required)
EULER_LIQUIDATOR_CONTRACT=0x...
SILO_LIQUIDATION_HELPER=0x...

# Aave V3 Sonic
AAVE_V3_POOL=0x...

# Thresholds (optional, defaults apply)
MIN_NET_PROFIT_USD=1
MIN_NET_PROFIT_FUNDED_USD=50
MAX_CAPITAL_PER_EXECUTION_USD=5000
GOVERNANCE_WAR_CHEST_USD=500

# Toolchain paths — use absolute paths to avoid PM2 PATH issues
# Install: cargo install heimdall-rs | foundryup | pip install halmos slither-analyzer | pipx install mythril
# Echidna: https://github.com/crytic/echidna/releases
HEIMDALL_PATH=/home/user/.cargo/bin/heimdall
ANVIL_PATH=/home/user/.local/bin/anvil
CAST_PATH=/home/user/.local/bin/cast
HALMOS_PATH=/home/user/.local/bin/halmos
ECHIDNA_PATH=/home/user/.local/bin/echidna
MYTHRIL_PATH=/home/user/.local/bin/myth
SLITHER_PATH=/home/user/.local/bin/slither

# Analysis thresholds
ORACLE_DIVERGENCE_ALERT_PCT=2
ORACLE_DIVERGENCE_CRITICAL_PCT=5
ORACLE_STALENESS_RATIO_THRESHOLD=5
TOXICITY_SCORE_BLOCK=50
TOXICITY_SCORE_REDUCE=30

# Feature flags
ENABLE_ORACLE_HUNTER=true
ENABLE_GOV_SHOCK=true
ENABLE_KILL_LIST=true
ENABLE_MISCONFIG_SNIPER=true
ENABLE_DEPLOY_MONITOR=true
ENABLE_STATIC_ANALYSIS=true
ENABLE_SYMBOLIC_EXEC=true
ENABLE_FUZZING=true

# Discord webhook for alerts (optional)
DISCORD_WEBHOOK_URL=

# PM2 / logging
LOG_LEVEL=info
LOG_DIR=./logs

# ─── Mass Audit Pipeline (Module G) ──────────────────────────────────

# Feature flags (opt-in — all default to false due to external API costs)
ENABLE_MASS_AUDIT=false
ENABLE_MASS_AUDIT_SONIC=true
ENABLE_MASS_AUDIT_ETHEREUM=false
ENABLE_LLM_ANALYSIS=false
# Differential compilation: requires solc-select (pip install solc-select)
ENABLE_DIFF_COMPILER=false

# Ethereum RPC (required if ENABLE_MASS_AUDIT_ETHEREUM=true)
RPC_URL_1=https://eth.llamarpc.com
WS_URL_1=

# Block explorer API keys (free tier: 5 req/sec)
# Get keys at: https://etherscan.io/myapikey and https://sonicscan.org/myapikey
ETHERSCAN_API_KEY=
SONICSCAN_API_KEY=

# Claude CLI path (uses OAuth — no API key needed)
# LLM analysis uses: claude --print --output-format json
CLAUDE_CLI_PATH=claude

# Mass audit tuning
MASS_AUDIT_INTERVAL_MS=1800000
MASS_AUDIT_MAX_PER_RUN=50
MASS_AUDIT_LLM_RISK_THRESHOLD=40
